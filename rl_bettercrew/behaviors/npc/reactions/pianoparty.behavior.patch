            "title": "dynamic",
            "type": "composite",
            "name": "dynamic",
            "parameters": {},
            "children": [
              {
                "title": "inverter",
                "type": "decorator",
                "name": "inverter",
                "parameters": {},
                "child": {
                  "title": "hasFlag",
                  "type": "action",
                  "name": "hasFlag",
                  "parameters": {
                    "name": {"key": "isPathfinding"}
                  }
                }
              },
              {
                "title": "failer",
                "type": "decorator",
                "name": "failer",
                "parameters": {},
                "child": {
                  "title": "timer",
                  "type": "action",
                  "name": "timer",
                  "parameters": {
                    "time": {"value": "<pathingTimeLimit>"}
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ],

