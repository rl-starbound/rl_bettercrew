      "value" : "isPathfinding"
    },
    { "op" : "replace",
      "path" : "/root/children/1/children/0/children/1/children/1",
      "value" : {
        "title": "parallel",
        "type": "composite",
        "name": "parallel",
        "parameters": {
          "fail": {"value": 1},
          "success": {"value": -1}
