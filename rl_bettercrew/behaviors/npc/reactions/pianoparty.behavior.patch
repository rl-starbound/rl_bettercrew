    { "op" : "test",
      "path" : "/root/children/1/children/0/children/1/children/1/type",
      "value" : "action"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/0/children/1/children/1/name",
      "value" : "moveToPosition"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/0/children/1/children/1/parameters/avoidLiquid/value",
      "value" : true
    },
    { "op" : "test",
