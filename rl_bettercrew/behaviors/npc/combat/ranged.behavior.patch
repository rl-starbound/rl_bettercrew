      "value" : "vecMultiply"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/0/child/children/3/children/0/children/1/children/1/children/2/children/2/child/children/1/parameters/first/key",
      "value" : "aimVector"
    },
    { "op" : "replace",
      "path" : "/root/children/1/children/0/child/children/3/children/0/children/1/children/1/children/2/children/2/child/children/1",
      "value" : {
