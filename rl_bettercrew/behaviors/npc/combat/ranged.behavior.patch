[
  // Fix a typo in which the wrong variable name is used, resulting in
  // calls to `moveToPosition` failing due to null input position.
  [
    { "op" : "test",
      "path" : "/root/children/0/children/1/type",
      "value" : "action"
    },
    { "op" : "test",
      "path" : "/root/children/0/children/1/name",
      "value" : "entityPosition"
    },
    { "op" : "test",
      "path" : "/root/children/0/children/1/parameters/entity/key",
      "value" : "target"
    },
    { "op" : "test",
      "path" : "/root/children/0/children/1/output/position",
      "value" : "movePosition"
    },
    { "op" : "replace",
      "path" : "/root/children/0/children/1/output/position",
      "value" : "rangedPosition"
    }
  ],

  // In the base game, the minimum firing distance for each weapon type
  // was ignored and the value 3 was used universally. In this mod, the
  // minimum distance is now half of the weapon's minimum distance, or
  // 5, whichever is smaller. If the NPC is too close to the target to
  // aim the ranged weapon, increment the `rangedWeaponCrowdedTicks`
  // counter, which eventually will allow the NPC to swap back to a
  // melee weapon. Reset this counter any time the NPC is far enough
  // away to aim the ranged weapon.
  [
    { "op" : "test",
      "path" : "/root/children/1/children/0/child/children/0/children/1/type",
      "value" : "decorator"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/0/child/children/0/children/1/name",
      "value" : "inverter"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/0/child/children/0/children/1/child/type",
      "value" : "action"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/0/child/children/0/children/1/child/name",
      "value" : "entityInRange"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/0/child/children/0/children/1/child/parameters/entity/key",
      "value" : "target"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/0/child/children/0/children/1/child/parameters/position/key",
      "value" : "self"
    },
    { "op" : "replace",
      "path" : "/root/children/1/children/0/child/children/0/children/1",
      "value" : {
        "title": "sequence",
        "type": "composite",
        "name": "sequence",
        "parameters": {},
        "children": [
          {
            "title": "multiply",
            "type": "action",
            "name": "multiply",
            "parameters": {
              "factor": {"value": 0.5},
              "number": {"key": "minRange"}
            },
            "output": {
              "result": "minFiringRange"
            }
          },
          {
            "title": "",
            "type": "action",
            "name": "rl_bettercrew_min",
            "parameters": {
              "first": {"value": 5},
              "second": {"key": "minFiringRange"}
            },
            "output": {
              "result": "minFiringRange"
            }
          },
          {
            "title": "inverter",
            "type": "decorator",
            "name": "inverter",
            "parameters": {},
            "child": {
              "title": "sequence",
              "type": "composite",
              "name": "sequence",
              "parameters": {},
              "children": [
                {
                  "title": "entityInRange",
                  "type": "action",
                  "name": "entityInRange",
                  "parameters": {
                    "entity": {"key": "target"},
                    "position": {"key": "self"},
                    "range": {"key": "minFiringRange"}
                  }
                },
                {
                  "title": "",
                  "type": "action",
                  "name": "rl_bettercrew_incrementCounter",
                  "parameters": {
                    "name": {"value": "rangedWeaponCrowdedTicks"}
                  }
                }
              ]
            }
          },
          {
            "title": "",
            "type": "action",
            "name": "rl_bettercrew_resetCounter",
            "parameters": {
              "name": {"value": "rangedWeaponCrowdedTicks"}
            }
          }
        ]
      }
    }
  ],

