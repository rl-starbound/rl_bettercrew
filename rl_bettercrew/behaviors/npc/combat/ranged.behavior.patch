  // Replace the base game `projectileAimVector` action with a version
  // that does not normalize the aim vector. The loss of precision of
  // floating point arithmetic caused by unnecessary normalization threw
  // off aim.
  [
    { "op" : "test",
      "path" : "/root/children/1/children/0/child/children/3/children/0/children/1/children/1/children/2/children/2/child/children/0/type",
      "value" : "action"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/0/child/children/3/children/0/children/1/children/1/children/2/children/2/child/children/0/name",
      "value" : "projectileAimVector"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/0/child/children/3/children/0/children/1/children/1/children/2/children/2/child/children/0/output/aimVector",
      "value" : "aimVector"
