    "path" : "/root/children/0/parameters/avoidLiquid/value",
    "value" : true
  },
  { "op" : "test",
    "path" : "/root/children/0/parameters/maxHeight/value",
    "value" : 5
  },
  { "op" : "test",
    "path" : "/root/children/0/parameters/minHeight/value",
