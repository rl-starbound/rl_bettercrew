        {
          "title": "Fail if in zero gravity",
          "type": "action",
          "name": "rl_bettercrew_gravityPositive",
          "parameters": {
            "position": {"key": "targetPosition"}
          }
        }
      ]
    }
  },
  { "op" : "add",
    "path" : "/scripts/-",
    "value" : "/scripts/actions/rl_bettercrew_world.lua"
  }
