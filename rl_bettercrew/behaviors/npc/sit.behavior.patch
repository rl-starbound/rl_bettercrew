[
  // If the NPC is a crew member on the ship, not following the player,
  // then the search radius for a chair is 300. Otherwise, it's 80, as
  // in the base game.
  [
    { "op" : "test",
      "path" : "/root/children/0/type",
      "value" : "action"
    },
    { "op" : "test",
      "path" : "/root/children/0/name",
      "value" : "findLoungable"
    },
    { "op" : "test",
      "path" : "/root/children/0/parameters/orderBy/value",
      "value" : "nearest"
    },
    { "op" : "test",
      "path" : "/root/children/0/parameters/orientation/value",
      "value" : "sit"
    },
    { "op" : "test",
      "path" : "/root/children/0/parameters/position/key",
      "value" : "spawn"
    },
    { "op" : "test",
      "path" : "/root/children/0/parameters/range/value",
      "value" : 80
    },
    { "op" : "test",
      "path" : "/root/children/0/parameters/unoccupied/value",
      "value" : true
    },
    { "op" : "test",
      "path" : "/root/children/0/output/list",
      "value" : "loungables"
    },
    { "op" : "replace",
      "path" : "/root/children/0",
      "value" : {
        "title": "selector",
        "type": "composite",
        "name": "selector",
        "parameters": {},
        "children": [
          {
            "title": "sequence",
            "type": "composite",
            "name": "sequence",
            "parameters": {},
            "children": [
              {
                "title": "hasRecruiter",
                "type": "action",
                "name": "hasRecruiter",
                "parameters": {}
              },
              {
                "title": "inverter",
                "type": "decorator",
                "name": "inverter",
                "parameters": {},
                "child": {
                  "title": "isFollowingRecruiter",
                  "type": "action",
                  "name": "isFollowingRecruiter",
                  "parameters": {}
                }
              },
              {
                "title": "Is ship world?",
                "type": "action",
                "name": "worldProperty",
                "parameters": {
                  "property": {"value": "ship.level"}
                }
              },
              {
                "title": "",
                "type": "action",
                "name": "rl_bettercrew_findLoungable",
                "parameters": {
                  "orderBy": {"value": "random"},
                  "orientation": {"value": "sit"},
                  "position": {"key": "spawn"},
                  "range": {"value": 300},
                  "unoccupied": {"value": true}
                },
                "output": {
                  "list": "loungables"
                }
              }
            ]
          },
          {
            "title": "",
            "type": "action",
            "name": "rl_bettercrew_findLoungable",
            "parameters": {
              "orderBy": {"value": "nearest"},
              "orientation": {"value": "sit"},
              "position": {"key": "spawn"},
              "range": {"value": 80},
              "unoccupied": {"value": true}
            },
            "output": {
              "list": "loungables"
            }
          }
        ]
      }
    }
  ],

  // If the position to which to move is on the floor of a one tile-
  // width solid floor, then the core engine may sometimes erroneously
  // move an NPC through the solid floor to get to the position. Adjust
  // the position up by 1/2 tile to prevent this.
  [
    { "op" : "test",
      "path" : "/root/children/3/type",
      "value" : "action"
    },
    { "op" : "test",
      "path" : "/root/children/3/name",
      "value" : "entityPosition"
    },
    { "op" : "test",
      "path" : "/root/children/3/parameters/entity/key",
      "value" : "chair"
    },
    { "op" : "test",
      "path" : "/root/children/3/output/position",
      "value" : "chair"
    },
    { "op" : "replace",
      "path" : "/root/children/3",
      "value" : {
        "title": "",
        "type": "composite",
        "name": "sequence",
        "parameters": {},
        "children": [
          {
            "title": "",
            "type": "action",
            "name": "entityPosition",
            "parameters": {
              "entity": {"key": "chair"}
            },
            "output": {
              "position": "chair"
            }
          },
          {
            "title": "",
            "type": "action",
            "name": "offsetPosition",
            "parameters": {
              "position": {"key": "chair"},
              "offset": {"value": [0, 0.5]}
            },
            "output": {
              "position": "chair"
            }
          }
        ]
      }
    }
  ],

  // Wrap the `moveToPosition` function in a pathfinding time limit to
  // prevent NPCs from freezing if the core engine cannot find a path to
  // the position.
  [
    { "op" : "test",
      "path" : "/root/children/4/children/1/type",
      "value" : "action"
    },
    { "op" : "test",
      "path" : "/root/children/4/children/1/name",
      "value" : "moveToPosition"
    },
    { "op" : "test",
      "path" : "/root/children/4/children/1/parameters/groundPosition/value",
      "value" : true
    },
    { "op" : "test",
      "path" : "/root/children/4/children/1/parameters/position/key",
      "value" : "chair"
    },
    { "op" : "replace",
      "path" : "/root/children/4/children/1",
      "value" : {
        "title": "parallel",
        "type": "composite",
        "name": "parallel",
        "parameters": {
          "fail": {"value": 1},
          "success": {"value": -1}
        },
        "children": [
          {
            "title": "",
            "type": "action",
            "name": "rl_bettercrew_moveToPosition",
            "parameters": {
              "groundPosition": {"value": true},
              "pathOptions": {"value": {"maxDistance": 400}},
              "position": {"key": "chair"}
            },
            "output": {
              "pathfinding": "isPathfinding"
            }
          },
          {
            "title": "dynamic",
            "type": "composite",
            "name": "dynamic",
            "parameters": {},
            "children": [
              {
                "title": "inverter",
                "type": "decorator",
                "name": "inverter",
                "parameters": {},
                "child": {
                  "title": "hasFlag",
                  "type": "action",
                  "name": "hasFlag",
                  "parameters": {
                    "name": {"key": "isPathfinding"}
                  }
                }
              },
              {
                "title": "failer",
                "type": "decorator",
                "name": "failer",
                "parameters": {},
                "child": {
                  "title": "timer",
                  "type": "action",
                  "name": "timer",
                  "parameters": {
                    "time": {"value": "<pathingTimeLimit>"}
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ],

  [
    { "op" : "add",
      "path" : "/scripts/-",
      "value" : "/scripts/actions/crew.lua"
    },
    { "op" : "add",
      "path" : "/scripts/-",
      "value" : "/scripts/actions/rl_bettercrew_move.lua"
    },
    { "op" : "add",
      "path" : "/scripts/-",
      "value" : "/scripts/actions/rl_bettercrew_query.lua"
    },
    { "op" : "add",
      "path" : "/parameters/pathingTimeLimit",
      "value" : 10
    }
  ]
]
