[
  // If the NPC is a crew member on the ship, not following the player,
  // then the search radius for a bed is 300. Otherwise, it's 50, as in
  // the base game.
  [
    { "op" : "test",
      "path" : "/root/children/0/type",
      "value" : "action"
    },
    { "op" : "test",
      "path" : "/root/children/0/name",
      "value" : "findLoungable"
    },
    { "op" : "test",
      "path" : "/root/children/0/parameters/orientation/value",
      "value" : "lay"
    },
    { "op" : "test",
      "path" : "/root/children/0/parameters/position/key",
      "value" : "spawn"
    },
    { "op" : "test",
      "path" : "/root/children/0/parameters/range/value",
      "value" : 50
    },
    { "op" : "test",
      "path" : "/root/children/0/output/entity",
      "value" : "bed"
    },
    { "op" : "replace",
      "path" : "/root/children/0",
      "value" : {
        "title": "sequence",
        "type": "composite",
        "name": "sequence",
        "parameters": {},
        "children": [
          {
            "title": "inverter",
            "type": "decorator",
            "name": "inverter",
            "parameters": {},
            "child": {
              "title": "sequence",
              "type": "composite",
              "name": "sequence",
              "parameters": {},
              "children": [
                {
                  "title": "hasRecruiter",
                  "type": "action",
                  "name": "hasRecruiter",
                  "parameters": {}
                },
                {
                  "title": "isFollowingRecruiter",
                  "type": "action",
                  "name": "isFollowingRecruiter",
                  "parameters": {}
                }
              ]
            }
          },
          {
            "title": "selector",
            "type": "composite",
            "name": "selector",
            "parameters": {},
            "children": [
              {
                "title": "sequence",
                "type": "composite",
                "name": "sequence",
                "parameters": {},
                "children": [
                  {
                    "title": "hasRecruiter",
                    "type": "action",
                    "name": "hasRecruiter",
                    "parameters": {}
                  },
                  {
                    "title": "Is ship world?",
                    "type": "action",
                    "name": "worldProperty",
                    "parameters": {
                      "property": {"value": "ship.level"}
                    }
                  },
                  {
                    "title": "",
                    "type": "action",
                    "name": "rl_bettercrew_findLoungable",
                    "parameters": {
                      "orderBy": {"value": "random"},
                      "orientation": {"value": "lay"},
                      "position": {"key": "spawn"},
                      "range": {"value": 300}
                    },
                    "output": {
                      "entity": "bed"
                    }
                  }
                ]
              },
              {
                "title": "",
                "type": "action",
                "name": "rl_bettercrew_findLoungable",
                "parameters": {
                  "orientation": {"value": "lay"},
                  "position": {"key": "spawn"},
                  "range": {"value": 50}
                },
                "output": {
                  "entity": "bed"
                }
              }
            ]
          }
        ]
      }
    }
  ],

  // If the position to which to move is on the floor of a one tile-
  // width solid floor, then the core engine may sometimes erroneously
  // move an NPC through the solid floor to get to the position. Adjust
  // the position up by 1/2 tile to prevent this.
  [
    { "op" : "test",
      "path" : "/root/children/1/children/1/children/0/type",
      "value" : "action"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/1/children/0/name",
      "value" : "entityPosition"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/1/children/0/parameters/entity/key",
      "value" : "bed"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/1/children/0/output/position",
      "value" : "bed"
    },
    { "op" : "replace",
      "path" : "/root/children/1/children/1/children/0",
      "value" : {
        "title": "",
        "type": "composite",
        "name": "sequence",
        "parameters": {},
        "children": [
          {
            "title": "",
            "type": "action",
            "name": "entityPosition",
            "parameters": {
              "entity": {"key": "bed"}
            },
            "output": {
              "position": "bed"
            }
          },
          {
            "title": "",
            "type": "action",
            "name": "offsetPosition",
            "parameters": {
              "position": {"key": "bed"},
              "offset": {"value": [0, 0.5]}
            },
            "output": {
              "position": "bed"
            }
          }
        ]
      }
    }
  ],

  // Wrap the `moveToPosition` function in a pathfinding time limit to
  // prevent NPCs from freezing if the core engine cannot find a path to
  // the position.
  [
    { "op" : "test",
      "path" : "/root/children/1/children/1/children/2/children/0/type",
      "value" : "action"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/1/children/2/children/0/name",
      "value" : "moveToPosition"
    },
    { "op" : "test",
      "path" : "/root/children/1/children/1/children/2/children/0/parameters/position/key",
      "value" : "bed"
    },
    { "op" : "replace",
      "path" : "/root/children/1/children/1/children/2/children/0",
      "value" : {
        "title": "parallel",
        "type": "composite",
        "name": "parallel",
        "parameters": {
          "fail": {"value": 1},
          "success": {"value": -1}
        },
        "children": [
          {
            "title": "",
            "type": "action",
            "name": "rl_bettercrew_moveToPosition",
            "parameters": {
              "pathOptions": {"value": {"maxDistance": 400}},
              "position": {"key": "bed"}
            },
            "output": {
              "pathfinding": "isPathfinding"
            }
          },
          {
            "title": "dynamic",
            "type": "composite",
            "name": "dynamic",
            "parameters": {},
            "children": [
              {
                "title": "inverter",
                "type": "decorator",
                "name": "inverter",
                "parameters": {},
                "child": {
                  "title": "hasFlag",
                  "type": "action",
                  "name": "hasFlag",
                  "parameters": {
                    "name": {"key": "isPathfinding"}
                  }
                }
              },
              {
                "title": "failer",
                "type": "decorator",
                "name": "failer",
                "parameters": {},
                "child": {
                  "title": "timer",
                  "type": "action",
                  "name": "timer",
                  "parameters": {
                    "time": {"value": "<pathingTimeLimit>"}
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ],

  [
    { "op" : "add",
      "path" : "/scripts/-",
      "value" : "/scripts/actions/crew.lua"
    },
    { "op" : "add",
      "path" : "/scripts/-",
      "value" : "/scripts/actions/rl_bettercrew_move.lua"
    },
    { "op" : "add",
      "path" : "/scripts/-",
      "value" : "/scripts/actions/rl_bettercrew_query.lua"
    },
    { "op" : "add",
      "path" : "/parameters/pathingTimeLimit",
      "value" : 10
    }
  ]
]
