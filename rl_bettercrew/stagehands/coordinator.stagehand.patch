[
  // In the base game, `forceMoveRange` for the npcbow was less than
  // `maxRange`. As a result, the coordinator could give an NPC a
  // "movePosition" (which is based on `maxRange`) to which the NPC
  // could route but from which they could not fire (which is based on
  // `forceMoveRange`, which is confusingly referred to as "maxRange"
  // when requested via the groupResource action). `forceMoveRange` must
  // be strictly greater than `maxRange` for the coordinator to provide
  // a usable "movePosition".
  { "op" : "replace",
    "path" : "/npcCombat/rangedWeaponRanges/npcbow/maxRange",
    "value" : 35
  },

  // Fix a crash bug in coordinator.lua.
  { "op" : "add",
    "path" : "/scripts/-",
    "value" : "/stagehands/rl_bettercrew_coordinator.lua"
  },

